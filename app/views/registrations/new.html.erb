<div class="max-w-md mx-auto mt-16 px-4">
  <h1 class="text-2xl font-semibold mb-2">Create Account</h1>
  <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
    Create a free account to save your practice sessions and chord progress permanently.
    Any data you've already recorded in this browser will be attached to your new account.
  </p>

  <% if flash[:alert] %>
    <div class="mb-4 p-3 bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200 rounded-lg text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: registration_path, method: :post do |f| %>
    <div class="mb-4">
      <%= f.label :name, "Name", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, required: true, autofocus: true, autocomplete: "name",
            class: "w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :email_address, "Email", class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, "Password", class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password",
            class: "w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="hidden" aria-hidden="true">
      <%= f.label :website, "Website" %>
      <%= f.text_field :website, autocomplete: "off", tabindex: -1 %>
    </div>

    <%= f.submit "Create Account", class: "w-full bg-blue-700 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-700 text-white font-medium rounded-lg text-sm px-4 py-2 cursor-pointer" %>
  <% end %>

  <p class="mt-4 text-sm text-center text-gray-600 dark:text-gray-400">
    Already have an account? <%= link_to "Sign in", new_login_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>
  </p>
</div>
