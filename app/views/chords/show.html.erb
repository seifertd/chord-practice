<div class="mt-6 space-y-6">

  <div>
    <h2 class="text-lg font-semibold mb-2">Chord Library</h2>
    <ul id="chord-library" class="flex flex-nowrap gap-3 overflow-x-auto pb-2">
      <% @chords.each do |chord| %>
        <li class="flex-none cursor-pointer rounded border border-gray-300 dark:border-gray-600 p-1 hover:bg-gray-100 dark:hover:bg-gray-700">
          <%= fret_board_svg(chord, size: :small) %>
        </li>
      <% end %>
    </ul>
  </div>

  <div>
    <h2 class="text-lg font-semibold mb-2">My Chords</h2>
    <ul id="my-chords" class="flex flex-nowrap gap-3 overflow-x-auto pb-2 min-h-24 border-2 border-dashed border-gray-300 dark:border-gray-600 rounded p-2">
      <li id="my-chords-empty" class="self-center px-4 text-gray-400 italic text-sm">Tap a chord to add it here</li>
    </ul>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const library  = document.getElementById('chord-library');
    const myChords = document.getElementById('my-chords');
    const empty    = document.getElementById('my-chords-empty');

    function updateEmpty() {
      const hasChords = myChords.querySelector('li:not(#my-chords-empty)');
      empty.style.display = hasChords ? 'none' : '';
    }

    library.addEventListener('click', function (e) {
      const item = e.target.closest('#chord-library > li');
      if (!item) return;
      myChords.appendChild(item);
      updateEmpty();
    });

    myChords.addEventListener('click', function (e) {
      const item = e.target.closest('#my-chords > li');
      if (!item || item.id === 'my-chords-empty') return;
      library.appendChild(item);
      updateEmpty();
    });
  });
</script>
