<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Chord Practice - An Application to Help Budding Guitarists Develop Chord Switching Speed and Accuracy</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="A website to help learning guitar players to develop faster and more accurate chord switching using an online application.">
    <meta name="keywords" content="guitar,chord,chord switching,practice">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= csrf_meta_tags %>
    <%= javascript_include_tag 'application' %>
  </head>
  <body class="bg-white dark:bg-gray-800 dark:text-white">

    <nav class="relative bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-4 py-2.5">
      <div class="flex items-center gap-4">

        <%= link_to root_url, class: "flex items-center gap-2" do %>
          <img src="<%= image_path 'guitar.png' %>" class="h-8" alt="Chord Practice Logo" />
          <span class="text-xl font-semibold whitespace-nowrap dark:text-white">Chord Practice</span>
        <% end %>

        <!-- Hamburger (mobile only) -->
        <button id="nav-toggle" class="md:hidden ml-auto p-2 rounded text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Nav links: hidden on mobile until toggled, always visible on md+ -->
        <div id="nav-menu" class="max-md:hidden md:flex items-center gap-2 max-md:absolute max-md:top-full max-md:right-0 max-md:bg-white max-md:dark:bg-gray-800 max-md:border max-md:border-gray-200 max-md:dark:border-gray-700 max-md:rounded-b-lg max-md:shadow-lg max-md:p-3 max-md:z-50">
          <% [
            ['Home',     root_path],
            ['Chords',   chords_path],
            ['Practice', sessions_path],
            ['Progress', progress_index_path],
          ].each do |label, path| %>
            <%= link_to label, path, class: "text-white bg-blue-700 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-700 font-medium rounded-lg text-sm px-4 py-2" %>
          <% end %>
          <% if authenticated? %>
            <span class="text-sm text-gray-500 dark:text-gray-400 px-2" title="<%= current_player.email_address %>"><%= current_player.name %></span>
            <%= button_to "Log out", login_path, method: :delete,
                  class: "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 font-medium rounded-lg text-sm px-4 py-2 cursor-pointer bg-transparent border-0" %>
          <% else %>
            <%= link_to "Log in", new_login_path, class: "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 font-medium rounded-lg text-sm px-4 py-2" %>
          <% end %>
        </div>

      </div>
    </nav>

    <% unless authenticated? %>
      <div class="bg-amber-50 dark:bg-amber-900/30 border-b border-amber-200 dark:border-amber-700 px-4 py-3 text-sm text-amber-800 dark:text-amber-300 flex items-center justify-between gap-4">
        <span>
          <strong>You're not logged in.</strong>
          Your practice data is saved temporarily in this browser, but will be lost if you clear cookies or switch devices.
          <%= link_to "Create a free account", new_registration_path, class: "underline hover:no-underline font-medium" %>
          to save your progress permanently.
        </span>
        <%= link_to "Sign in", new_login_path, class: "shrink-0 text-amber-800 dark:text-amber-300 underline hover:no-underline font-medium" %>
      </div>
    <% end %>

    <main class="px-4 py-4">
      <%= yield %>
    </main>

    <script>
      document.getElementById('nav-toggle').addEventListener('click', function () {
        var menu = document.getElementById('nav-menu');
        var open = menu.classList.toggle('max-md:hidden');
        menu.classList.toggle('flex', !open);
        menu.classList.toggle('flex-col', !open);
      });
    </script>

  </body>
</html>
