<div class="mt-6">
  <h2 class="text-lg font-semibold mb-4">Progress</h2>

  <% if @progress[:data][:datasets].empty? %>
    <% if current_player.chords.length > 1 %>
      <div class="p-4 text-sm text-blue-800 bg-blue-50 rounded-lg dark:bg-blue-900/30 dark:text-blue-300">
        <strong>Hey!</strong> You have no practice sessions yet. Why not
        <%= link_to "start one?", sessions_path, class: "underline hover:no-underline" %>
      </div>
    <% else %>
      <div class="p-4 text-sm text-blue-800 bg-blue-50 rounded-lg dark:bg-blue-900/30 dark:text-blue-300">
        <strong>Hey!</strong> You haven't added enough chords yet. Why not
        <%= link_to "tell us about your chords?", chords_path, class: "underline hover:no-underline" %>
      </div>
    <% end %>
  <% else %>
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <div class="flex rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600 text-sm">
        <button onclick="setRange('month')" id="btn-month"
                class="range-btn px-3 py-1.5 bg-blue-600 text-white">Last Month</button>
        <button onclick="setRange('year')" id="btn-year"
                class="range-btn px-3 py-1.5 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600">Last Year</button>
        <button onclick="setRange('all')" id="btn-all"
                class="range-btn px-3 py-1.5 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600">All Time</button>
      </div>

      <select id="pair-filter" onchange="filterPair(this.value)"
              class="min-w-36 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1.5 text-sm">
        <option value="all">All Pairs</option>
        <option value="_custom_" style="display:none">Custom</option>
        <% @progress[:data][:datasets].each do |ds| %>
          <option value="<%= ds[:label] %>"><%= ds[:label] %></option>
        <% end %>
      </select>
    </div>

    <%# Insight cards — click any coloured card to highlight that pair on the chart %>
    <% if @stats && (@stats[:overall_pct] || @stats[:most_improved] || @stats[:most_practiced]) %>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">

        <%# Overall Progress (stat only, not clickable) %>
        <% if @stats[:overall_pct] %>
          <% positive = @stats[:overall_pct] >= 0 %>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Overall Progress</div>
            <div class="text-2xl font-bold <%= positive ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400' %>">
              <%= positive ? '+' : '' %><%= @stats[:overall_pct] %>%
            </div>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">avg improvement, all pairs</div>
          </div>
        <% end %>

        <%# Most Improved %>
        <% if @stats[:most_improved] %>
          <% p = @stats[:most_improved] %>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-3
                      cursor-pointer hover:border-blue-400 dark:hover:border-blue-500
                      hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors"
               onclick="filterPair('<%= j(p[:label]) %>'); document.getElementById('pair-filter').value = '<%= j(p[:label]) %>';"
               title="Click to highlight on chart">
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Most Improved ↑</div>
            <div class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate"><%= p[:label] %></div>
            <div class="text-xs text-green-600 dark:text-green-400 mt-1">
              +<%= p[:pct] %>% &bull; <%= p[:first] %> → <%= p[:last] %> sw/min
            </div>
          </div>
        <% end %>

        <%# Needs Work (least improved / most regressed) %>
        <% if @stats[:least_improved] %>
          <% p = @stats[:least_improved] %>
          <% positive = p[:pct] >= 0 %>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-3
                      cursor-pointer hover:border-blue-400 dark:hover:border-blue-500
                      hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors"
               onclick="filterPair('<%= j(p[:label]) %>'); document.getElementById('pair-filter').value = '<%= j(p[:label]) %>';"
               title="Click to highlight on chart">
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Needs Work ↓</div>
            <div class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate"><%= p[:label] %></div>
            <div class="text-xs <%= positive ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-500 dark:text-red-400' %> mt-1">
              <%= positive ? '+' : '' %><%= p[:pct] %>% &bull; <%= p[:first] %> → <%= p[:last] %> sw/min
            </div>
          </div>
        <% end %>

        <%# Most Practiced %>
        <% if @stats[:most_practiced] %>
          <% p = @stats[:most_practiced] %>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-3
                      cursor-pointer hover:border-blue-400 dark:hover:border-blue-500
                      hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors"
               onclick="filterPair('<%= j(p[:label]) %>'); document.getElementById('pair-filter').value = '<%= j(p[:label]) %>';"
               title="Click to highlight on chart">
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Most Practiced</div>
            <div class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate"><%= p[:label] %></div>
            <div class="text-xs text-blue-600 dark:text-blue-400 mt-1">
              <%= p[:count] %> <%= 'session'.pluralize(p[:count]) %>
            </div>
          </div>
        <% end %>

      </div>
    <% end %>

    <div class="relative">
      <canvas id="progressChart"></canvas>
    </div>

    <script>
      (function () {
        var PALETTE = "8dd3c7ffffb3bebadafb807280b1d3fdb462b3de69fccde5d9d9d9bc80bdccebc5ffed6f";
        function paletteColor(i, opacity) {
          var offset = (i % 12) * 6;
          var hex = PALETTE.substring(offset, offset + 6);
          var r = parseInt(hex.substring(0, 2), 16);
          var g = parseInt(hex.substring(2, 4), 16);
          var b = parseInt(hex.substring(4, 6), 16);
          return "rgba(" + r + "," + g + "," + b + "," + opacity + ")";
        }

        function initChart() {
          var config = <%= raw @progress.to_json %>;
          config.data.datasets.forEach(function (dataset, i) {
            dataset.borderColor = paletteColor(i, 1.0);
            dataset.backgroundColor = paletteColor(i, 0.3);
          });
          config.options.plugins = {
            legend: {
              onClick: function(e, legendItem, legend) {
                var ds = legend.chart.data.datasets[legendItem.datasetIndex];
                ds.hidden = !ds.hidden;
                recalcYMax();
                legend.chart.update();
                var select = document.getElementById('pair-filter');
                if (select) select.value = '_custom_';
              }
            }
          };
          var chart = new Chart("progressChart", config);
          var currentXMin = null;

          function recalcYMax() {
            var yMax = 0;
            chart.data.datasets.forEach(function(ds) {
              if (ds.hidden) return;
              ds.data.forEach(function(point) {
                if (!currentXMin || new Date(point.x) >= currentXMin) {
                  yMax = Math.max(yMax, point.y);
                }
              });
            });
            chart.options.scales.y.max = yMax > 0 ? Math.ceil(yMax * 1.1) : undefined;
          }

          function setRange(range) {
            var now = new Date();
            if (range === 'month') {
              currentXMin = new Date(now.getFullYear(), now.getMonth() - 1, now.getDate());
            } else if (range === 'year') {
              currentXMin = new Date(now.getFullYear() - 1, now.getMonth(), now.getDate());
            } else {
              currentXMin = null;
            }
            chart.options.scales.x.min = currentXMin ? currentXMin.toISOString() : undefined;
            recalcYMax();
            chart.update();

            document.querySelectorAll('.range-btn').forEach(function(btn) {
              var active = btn.id === 'btn-' + range;
              btn.classList.toggle('bg-blue-600', active);
              btn.classList.toggle('text-white', active);
              btn.classList.toggle('bg-white', !active);
              btn.classList.toggle('dark:bg-gray-700', !active);
              btn.classList.toggle('text-gray-700', !active);
              btn.classList.toggle('dark:text-gray-300', !active);
            });
          }

          function filterPair(label) {
            chart.data.datasets.forEach(function(ds) {
              ds.hidden = label !== 'all' && ds.label !== label;
            });
            recalcYMax();
            chart.update();
          }

          window.setRange = setRange;
          window.filterPair = filterPair;
          setRange('month');
        }

        if (typeof Chart !== 'undefined') {
          initChart();
        } else {
          var s1 = document.createElement('script');
          s1.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js';
          s1.onload = function () {
            var s2 = document.createElement('script');
            s2.src = 'https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js';
            s2.onload = initChart;
            document.head.appendChild(s2);
          };
          document.head.appendChild(s1);
        }
      })();
    </script>
  <% end %>
</div>
